PORT=5003
NODE_ENV=development
DATABASE_URL=file:./dev.db
JWT_SECRET=change_this_super_secret
JWT_EXPIRES_IN=7d
HMAC_SECRET=change_this_hmac_secret
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5003
KIOSK_DEVICE_KEYS=kiosk-01:change-me

# Twilio (optional; leave empty for mock SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# SMTP (optional; leave empty for mock email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Default admin seeding (for local/dev)
DEFAULT_ADMIN_NAME=SUVIDHA Admin
DEFAULT_ADMIN_MOBILE=9999999999
DEFAULT_ADMIN_EMAIL=admin@suvidha.local
DEFAULT_ADMIN_PASSWORD=Admin@123
