{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix client && npm install --prefix server",
  "buildCommand": "cd server && DATABASE_URL=file:./prisma/dev.db npx prisma generate && cd ../client && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "cleanUrls": true,
  "functions": {
    "api/health.js": {
      "includeFiles": "server/**"
    },
    "api/admin/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/auth/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/complaints/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/documents/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/health/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/payments/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/services/[...path].js": {
      "includeFiles": "server/**"
    },
    "api/sync/[...path].js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
